# Absolute path to repo root (parent of apps/). Defaults to ../.. relative to apps/web/.
# SHOP_REPO_ROOT=/absolute/path/to/17.11 Deployment

# Optional override for SQLite file
# SHOP_DB_PATH=/absolute/path/to/data/sqlite/shop.db

# Supabase/Postgres connection string used in production
# DATABASE_URL=postgresql://...

# External scoring endpoint used in production for /api/scoring
# SCORING_URL=https://your-service.example.com/scoring

# Python for POST /api/scoring (default: python3)
# PYTHON_PATH=/usr/bin/python3
